---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HowToOrder from '../components/HowToOrder.astro';
import { site } from '../config';
import '../styles/catalog.css';
import { getImage } from 'astro:assets';
import rabbitImgSrc from '../assets/hero-rabbit.png';

const optimizedRabbit = await getImage({ src: rabbitImgSrc, width: 389, height: 420, format: 'webp' });

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": site.name,
  "url": Astro.site?.toString() ?? "https://babusyni-igrashky.com.ua/",
  "description": site.description,
  "image": new URL('/og-default.png', Astro.site || 'https://babusyni-igrashky.com.ua/').toString(),
  "telephone": site.phone,
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "UA",
    "addressLocality": site.location,
  },
  "sameAs": [
    `https://t.me/${site.telegram}`,
    `https://www.instagram.com/${site.instagram}`,
  ],
};
---

<BaseLayout schema={schema} preloadImage={optimizedRabbit.src}>
  <Hero />

  <section id="katalog" class="section catalog">
    <div class="container">
      <div class="catalog-head">
        <p class="eyebrow">Каталог</p>
        <h2>Наші іграшки</h2>
        <p class="catalog-lead">
          Оберіть готову іграшку або замовте схожу — кольори й деталі узгодимо
          особисто.
        </p>
      </div>

      <div class="catalog-grid" id="catalog-grid"></div>
    </div>
  </section>

  <HowToOrder />
</BaseLayout>

<style>
  .catalog-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .catalog-lead {
    color: var(--color-muted);
    max-width: 48ch;
    margin-inline: auto;
  }
  .catalog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .catalog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .catalog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
