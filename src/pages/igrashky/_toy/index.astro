---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { site } from '../../../config';

const absoluteCanonical = new URL(Astro.url.pathname, Astro.site || 'https://babusyni-igrashky.com.ua/').toString();

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "",
  "image": [],
  "offers": {
    "@type": "Offer",
    "priceCurrency": "UAH",
    "price": "",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Головна",
      "item": Astro.site?.toString() ?? "https://babusyni-igrashky.com.ua/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "",
      "item": absoluteCanonical
    }
  ]
};

const schemas = [productSchema, breadcrumbSchema];
---

<BaseLayout
  title=""
  description=""
  ogType="product"
  schema={schemas}
>
  <article class="section product">
    <div class="container">
      <span hidden data-kv="galleryCount"></span>
      <span hidden data-kv="spinCount"></span>
      <p class="crumbs"><a href="/#katalog">← До каталогу</a></p>

      <div class="product-grid">
        <div class="product-media">
          <div id="dynamic-spin" data-alt=""></div>
          <div class="product-gallery">
            <div id="dynamic-gallery" data-alt=""></div>
          </div>
        </div>

        <div class="product-info">
          <span class="badge" data-kv="status"></span>
          <h1 data-kv="title"></h1>
          <p class="product-price"><span data-kv="price"></span> грн</p>

          <dl class="specs">
            <div><dt>Розмір</dt><dd data-kv="size"></dd></div>
            <div><dt>Матеріали</dt><dd data-kv="materials"></dd></div>
          </dl>

          <div class="product-desc" data-kv="description">
          </div>

          <a class="btn btn-primary" href={`https://t.me/${site.telegram}`} target="_blank" rel="noopener noreferrer">Замовити цю іграшку</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .crumbs {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .product-grid {
    display: grid;
    gap: 2rem;
  }
  .product-gallery {
    margin-top: 1rem;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .badge-available {
    background: #547c47;
  }
  .badge-made-to-order {
    background: var(--color-secondary);
    color: var(--color-text);
  }
  .badge-sold {
    background: var(--color-muted);
  }

  .product-price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.9rem;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .specs {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
  }
  .specs div {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.5rem;
  }
  .specs dt {
    color: var(--color-muted);
    font-weight: 600;
  }
  .specs dd {
    margin: 0;
  }

  .product-desc {
    margin-bottom: 1.5rem;
  }

  .sold-note {
    background: color-mix(in srgb, var(--color-secondary) 18%, var(--color-bg));
    border-radius: var(--radius-sm);
    padding: 0.9rem 1.1rem;
    color: var(--color-text);
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
  }
</style>
