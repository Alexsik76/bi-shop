---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { site } from '../../../config';

const absoluteCanonical = new URL(Astro.url.pathname, Astro.site || 'https://babusyni-igrashky.com.ua/').toString();

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "",
  "image": [],
  "offers": {
    "@type": "Offer",
    "priceCurrency": "UAH",
    "price": "",
    "availability": "https://schema.org/InStock"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Головна",
      "item": Astro.site?.toString() ?? "https://babusyni-igrashky.com.ua/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "",
      "item": absoluteCanonical
    }
  ]
};

const schemas = [productSchema, breadcrumbSchema];
---

<BaseLayout
  title=""
  description=""
  ogType="product"
  schema={schemas}
>
  <article class="section product">
    <div class="container">
      <span hidden data-kv="galleryCount"></span>
      <span hidden data-kv="spinCount"></span>
      <p class="crumbs"><a href="/#katalog">← До каталогу</a></p>

      <div class="product-grid">
        <div class="product-media">
          <div id="dynamic-spin" data-alt=""></div>
          <div class="product-gallery">
            <div id="dynamic-gallery" data-alt=""></div>
          </div>
        </div>

        <div class="product-info">
          <span class="badge" data-kv="status"></span>
          <h1 data-kv="title"></h1>
          <p class="product-price"><span data-kv="price"></span> грн</p>

          <dl class="specs">
            <div><dt>Розмір</dt><dd data-kv="size"></dd></div>
            <div><dt>Матеріали</dt><dd data-kv="materials"></dd></div>
          </dl>

          <div class="product-desc" data-kv="description">
          </div>

          <a class="btn btn-primary" href={`https://t.me/${site.telegram}`} target="_blank" rel="noopener noreferrer">Замовити цю іграшку</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  // Gallery logic
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((gal) => {
    const mains = gal.querySelectorAll<HTMLElement>('[data-main-img]');
    const thumbs = gal.querySelectorAll<HTMLElement>('[data-thumb]');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const i = thumb.dataset.thumb;
        mains.forEach((m) =>
          m.classList.toggle('is-active', m.dataset.mainImg === i)
        );
        thumbs.forEach((t) =>
          t.classList.toggle('is-active', t.dataset.thumb === i)
        );
      });
    });
  });

  // Spin logic
  function initSpin(el: HTMLElement) {
    const urls = JSON.parse(el.dataset.urls || '[]') as string[];
    const frames = urls.length;
    if (frames === 0) return;

    const img = el.querySelector<HTMLImageElement>('.spin-img')!;
    const loader = el.querySelector<HTMLElement>('[data-loader]')!;
    const hint = el.querySelector<HTMLElement>('[data-hint]')!;
    const stage = el.querySelector<HTMLElement>('.spin-stage')!;

    let loaded = 0;
    let loadingStarted = false;
    let dragging = false;
    let startX = 0;
    let startIndex = 0;
    let interacted = false;
    let index = 0;

    const show = (i: number) => {
      index = ((i % frames) + frames) % frames;
      img.src = urls[index];
    };

    function startPreloading() {
      if (loadingStarted) return;
      loadingStarted = true;

      loader.classList.add('is-loading');

      urls.forEach((url) => {
        const im = new Image();
        im.onload = im.onerror = () => {
          if (++loaded === frames) {
            loader.classList.remove('is-loading');
            loader.style.display = 'none';
            show(0);
          }
        };
        im.src = url;
      });
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startPreloading();
            obs.unobserve(el);
          }
        });
      },
      { rootMargin: '200px' }
    );

    observer.observe(el);

    const begin = (x: number) => {
      if (loaded < frames) return;
      dragging = true;
      startX = x;
      startIndex = index;
      if (!interacted) {
        interacted = true;
        hint.style.opacity = '0';
      }
    };
    const move = (x: number) => {
      if (!dragging) return;
      const pxPerFrame = Math.max(4, stage.clientWidth / frames);
      show(startIndex - Math.round((x - startX) / pxPerFrame));
    };
    const end = () => {
      dragging = false;
    };

    stage.addEventListener('pointerdown', (e) => {
      (e.target as HTMLElement).setPointerCapture?.(e.pointerId);
      begin(e.clientX);
    });
    stage.addEventListener('pointermove', (e) => move(e.clientX));
    stage.addEventListener('pointerup', end);
    stage.addEventListener('pointercancel', end);
    stage.addEventListener('pointerleave', end);

    stage.addEventListener('keydown', (e) => {
      if (loaded < frames) return;

      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        show(index - 1);
        if (!interacted) {
          interacted = true;
          hint.style.opacity = '0';
        }
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        show(index + 1);
        if (!interacted) {
          interacted = true;
          hint.style.opacity = '0';
        }
      }
    });
  }

  document.querySelectorAll<HTMLElement>('[data-spin]').forEach(initSpin);
</script>

<style>
  .crumbs {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .product-grid {
    display: grid;
    gap: 2rem;
  }
  .product-gallery {
    margin-top: 1rem;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .badge-available {
    background: #547c47;
  }
  .badge-made-to-order {
    background: var(--color-secondary);
    color: var(--color-text);
  }
  .badge-sold {
    background: var(--color-muted);
  }

  .product-price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.9rem;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .specs {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
  }
  .specs div {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.5rem;
  }
  .specs dt {
    color: var(--color-muted);
    font-weight: 600;
  }
  .specs dd {
    margin: 0;
  }

  .product-desc {
    margin-bottom: 1.5rem;
  }

  .sold-note {
    background: color-mix(in srgb, var(--color-secondary) 18%, var(--color-bg));
    border-radius: var(--radius-sm);
    padding: 0.9rem 1.1rem;
    color: var(--color-text);
  }

  /* Gallery Styles */
  .gallery-main {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .gallery-main img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .gallery-main img.is-active {
    opacity: 1;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    flex-wrap: wrap;
  }
  .thumb {
    width: 68px;
    height: 68px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
    transition: border-color 0.15s ease;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb.is-active {
    border-color: var(--color-accent);
  }

  /* Spin Styles */
  .spin {
    width: 100%;
  }
  .spin-stage {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }
  .spin-stage:active {
    cursor: grabbing;
  }
  .spin-stage:focus-visible {
    outline: 3px solid var(--color-secondary);
    outline-offset: 2px;
  }
  .spin-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .spin-loader {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.8rem;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-text);
    font-size: 0.8rem;
    box-shadow: var(--shadow);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .spin-loader.is-loading {
    opacity: 1;
    visibility: visible;
  }
  .spin-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid var(--color-line);
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: spin-rotate 0.8s linear infinite;
  }
  @keyframes spin-rotate {
    to {
      transform: rotate(360deg);
    }
  }

  .spin-hint {
    position: absolute;
    bottom: 0.9rem;
    left: 50%;
    transform: translateX(-50%);
    background: color-mix(in srgb, var(--color-text) 82%, transparent);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 0.82rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .spin-spinner {
      animation: none;
    }
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
  }
</style>
