---
import { getCollection, render } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Spin360 from '../../components/Spin360.astro';
import Gallery from '../../components/Gallery.astro';
import OrderButton from '../../components/OrderButton.astro';
import { site } from '../../config';
import { statusMeta } from '../../lib/status';

export async function getStaticPaths() {
  const toys = await getCollection('igrashky');
  return toys.map((toy) => ({
    params: { slug: toy.id },
    props: { toy },
  }));
}

interface Props {
  toy: CollectionEntry<'igrashky'>;
}

const { toy } = Astro.props;
const { title = 'Іграшка', price, size, materials, status = 'available', cover, gallery } =
  toy.data;
const { Content } = await render(toy);

// Збір та оптимізація кадрів обертання для поточної іграшки.
const framesGlob = import.meta.glob('../../content/igrashky/*/spin/*.webp', { eager: true });
const toySlug = toy.id;
const toyFramesPaths = Object.keys(framesGlob)
  .filter((path) => path.includes(`/content/igrashky/${toySlug}/spin/`))
  .sort((a, b) => a.localeCompare(b, 'en', { numeric: true }));

const resolvedFrames = await Promise.all(
  toyFramesPaths.map(async (p) => {
    const imgMetadata = (framesGlob[p] as any).default;
    const optimized = await getImage({ src: imgMetadata, width: 800, height: 800, format: 'webp' });
    return optimized.src;
  })
);

const badge = statusMeta[status] || statusMeta.available;
const priceFormatted = price !== undefined && price !== null ? new Intl.NumberFormat('uk-UA').format(price) : '';

// Зображення для Open Graph.
const og = await getImage({ src: cover, width: 1200, height: 1200, format: 'webp' });

// Постер для 3D-обертання.
const poster = await getImage({ src: cover, width: 800, height: 800, format: 'webp' });

const sizeText = size ? `, ${size}` : '';
const materialsText = materials ? `. Матеріали: ${materials}` : '';
const priceText = priceFormatted ? `. Ціна ${priceFormatted} грн.` : '';
const metaDescription = `${title} — м’яка іграшка ручної роботи${sizeText}${materialsText}${priceText}`;

const absoluteCanonical = new URL(Astro.url.pathname, Astro.site || 'https://babusyni-igrashky.com.ua/').toString();
const absoluteCoverUrl = new URL(og.src, Astro.site || 'https://babusyni-igrashky.com.ua/').toString();

const availabilityMap = {
  'available': "https://schema.org/InStock",
  'made-to-order': "https://schema.org/MadeToOrder",
  'sold': "https://schema.org/SoldOut"
};
const availability = availabilityMap[status] || "https://schema.org/InStock";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": title,
  "description": metaDescription,
  "image": absoluteCoverUrl,
  ...(materials ? { "material": materials } : {}),
  ...(size ? { "size": size } : {}),
  "brand": {
    "@type": "Brand",
    "name": site.name
  },
  "offers": {
    "@type": "Offer",
    ...(price !== undefined ? { "price": price } : {}),
    "priceCurrency": "UAH",
    "availability": availability,
    "url": absoluteCanonical,
    "seller": {
      "@type": "Organization",
      "name": site.name
    }
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Головна",
      "item": Astro.site?.toString() ?? "https://babusyni-igrashky.com.ua/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": title,
      "item": absoluteCanonical
    }
  ]
};

const schemas = [productSchema, breadcrumbSchema];
---

<BaseLayout
  title={title}
  description={metaDescription}
  ogImage={og.src}
  ogType="product"
  productPrice={price}
  schema={schemas}
>
  <article class="section product">
    <div class="container">
      <p class="crumbs"><a href="/#katalog">← До каталогу</a></p>

      <div class="product-grid">
        <div class="product-media">
  {resolvedFrames.length > 0 ? (
    <Spin360
      frames={resolvedFrames}
      alt={title}
      poster={{
        src: poster.src,
        width: Number(poster.attributes.width ?? 800),
        height: Number(poster.attributes.height ?? 800),
      }}
    />
  ) : (
    <Image
      src={cover}
      alt={title}
      width={800}
      height={800}
      format="webp"
    />
  )}
  <div class="product-gallery">
    <Gallery images={gallery} alt={title} />
  </div>
</div>

        <div class="product-info">
          {badge && <span class={`badge badge-${badge.kind}`}>{badge.label}</span>}
          <h1>{title}</h1>
          {priceFormatted && <p class="product-price">{priceFormatted} грн</p>}

          {(size || materials) && (
            <dl class="specs">
              {size && <div><dt>Розмір</dt><dd>{size}</dd></div>}
              {materials && <div><dt>Матеріали</dt><dd>{materials}</dd></div>}
            </dl>
          )}

          <div class="product-desc">
            <Content />
          </div>

          {status === 'sold' ? (
            <p class="sold-note">
              Ця іграшка вже знайшла свою домівку. Проте ми можемо зв'язати схожу на замовлення спицями: колір пряжі та деталі узгоджуємо окремо.
            </p>
          ) : null}

          {status === 'made-to-order' ? (
            <p class="sold-note">
              Ця іграшка в'яжеться під замовлення. Ми зв'яжемо її спеціально для вас спицями: колір пряжі та деталі узгоджуємо окремо.
            </p>
          ) : null}

          <OrderButton toyTitle={title} label="Замовити цю іграшку" />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .crumbs {
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }
  .product-grid {
    display: grid;
    gap: 2rem;
  }
  .product-gallery {
    margin-top: 1rem;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.32rem 0.8rem;
    border-radius: 999px;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .badge-available {
    background: #547c47;
  }
  .badge-made-to-order {
    background: var(--color-secondary);
    color: var(--color-text);
  }
  .badge-sold {
    background: var(--color-muted);
  }

  .product-price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.9rem;
    color: var(--color-accent);
    margin: 0 0 1.25rem;
  }

  .specs {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
  }
  .specs div {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 0.5rem;
  }
  .specs dt {
    color: var(--color-muted);
    font-weight: 600;
  }
  .specs dd {
    margin: 0;
  }

  .product-desc {
    margin-bottom: 1.5rem;
  }

  .sold-note {
    background: color-mix(in srgb, var(--color-secondary) 18%, var(--color-bg));
    border-radius: var(--radius-sm);
    padding: 0.9rem 1.1rem;
    color: var(--color-text);
  }

  @media (min-width: 1024px) {
    .product-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
  }
</style>
