---
import type { CollectionEntry } from 'astro:content';
import { statusMeta } from '../lib/status';
import { site } from '../config';

interface Props {
  toy: CollectionEntry<'igrashky'>;
}

const { toy } = Astro.props;
const { title, price, size, status = 'available' } = toy.data;
const slug = toy.id;

const badge = statusMeta[status] || statusMeta.available;
const isSold = status === 'sold';
const priceFormatted = price !== undefined && price !== null ? new Intl.NumberFormat('uk-UA').format(price) : '';

const coverUrl = `${site.r2Url}/${slug}/cover.webp`;
const coverSmUrl = `${site.r2Url}/${slug}/cover-sm.webp`;
---

<article class={`card ${isSold ? 'is-sold' : ''}`} data-toy-id={toy.id}>
  <a href={`/igrashky/${slug}/`} class="card-link">
    <div class="card-media">
      <img
        src={coverUrl}
        srcset={`${coverSmUrl} 640w, ${coverUrl} 1200w`}
        sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 90vw"
        width="600"
        height="800"
        alt={`Іграшка «${title || ''}»`}
        decoding="async"
      />
      <span class={`badge badge-${badge.kind}`} data-kv="status">{toy.data.status ? (statusMeta[toy.data.status]?.label || '') : ''}</span>

    </div>
    <div class="card-body">
      <h3 class="card-title" data-kv="title">{title || ''}</h3>
      {size && <p class="card-size">{size}</p>}
      <p class="card-price"><span data-kv="price">{priceFormatted || ''}</span> грн</p>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.22s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.22s ease;
  }
  .card:not(.is-sold):hover {
    transform: translateY(-6px) rotate(-1deg);
    box-shadow: 0 20px 40px rgba(74, 59, 50, 0.14);
  }
  .card-link {
    color: inherit;
    display: block;
  }
  .card-link:hover {
    text-decoration: none;
  }

  .card-media {
    position: relative;
    aspect-ratio: 3 / 4;
    background: var(--color-bg);
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    color: #fff;
    letter-spacing: 0.02em;
  }
  .badge-available {
    background: #547c47;
  }
  .badge-made-to-order {
    background: var(--color-secondary);
    color: var(--color-text);
  }
  .badge-sold {
    background: var(--color-muted);
  }

  .sold-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: #fff;
    background: rgba(74, 59, 50, 0.72);
    text-transform: uppercase;
  }

  .is-sold .card-media img {
    filter: grayscale(0.85);
    opacity: 0.55;
  }
  .is-sold .card-title {
    color: var(--color-muted);
  }
  .is-sold .card-price {
    color: var(--color-muted);
  }

  .card-body {
    padding: 1rem 1.1rem 1.25rem;
  }
  .card-title {
    margin: 0 0 0.2rem;
    font-size: 1.15rem;
    transition: color 0.15s ease;
  }
  .card-size {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }
  .card-price {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--color-accent);
    transition: color 0.15s ease;
  }
</style>
