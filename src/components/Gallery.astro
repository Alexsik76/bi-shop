---
interface Props {
  toyId: string;
  galleryCount: number;
  r2Url: string;
  alt: string;
}

const { toyId, galleryCount, r2Url, alt } = Astro.props;

const images = Array.from({ length: galleryCount }, (_, i) => {
  const n = i + 1;
  return {
    full: `${r2Url}/${toyId}/gallery-${n}.webp`,
    sm: `${r2Url}/${toyId}/gallery-${n}-sm.webp`,
  };
});
---

<div id="dynamic-gallery" data-toy-id={toyId} data-alt={alt}></div>

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((gal) => {
    const mains = gal.querySelectorAll<HTMLElement>('[data-main-img]');
    const thumbs = gal.querySelectorAll<HTMLElement>('[data-thumb]');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const i = thumb.dataset.thumb;
        mains.forEach((m) =>
          m.classList.toggle('is-active', m.dataset.mainImg === i),
        );
        thumbs.forEach((t) =>
          t.classList.toggle('is-active', t.dataset.thumb === i),
        );
      });
    });
  });
</script>

<style>
  .gallery-main {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .gallery-main img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .gallery-main img.is-active {
    opacity: 1;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    flex-wrap: wrap;
  }
  .thumb {
    width: 68px;
    height: 68px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
    transition: border-color 0.15s ease;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb.is-active {
    border-color: var(--color-accent);
  }
</style>
