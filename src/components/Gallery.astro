---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  alt: string;
}

const { images, alt } = Astro.props;
---

{
  images.length > 0 && (
    <div class="gallery" data-gallery>
      <div class="gallery-main">
        {images.map((img, i) => (
          <Image
            src={img}
            alt={`${alt} — фото ${i + 1}`}
            width={900}
            height={900}
            widths={[450, 900]}
            sizes="(min-width: 1024px) 500px, 90vw"
            format="webp"
            quality={80}
            class={i === 0 ? 'is-active' : ''}
            data-main-img={i}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding={i === 0 ? 'sync' : 'async'}
          />
        ))}
      </div>

      {images.length > 1 && (
        <ul class="gallery-thumbs">
          {images.map((img, i) => (
            <li>
              <button
                type="button"
                class={`thumb ${i === 0 ? 'is-active' : ''}`}
                data-thumb={i}
                aria-label={`Показати фото ${i + 1}`}
              >
                <Image
                  src={img}
                  alt=""
                  width={140}
                  height={140}
                  format="webp"
                  quality={70}
                  loading="lazy"
                  decoding="async"
                />
              </button>
            </li>
          ))}
        </ul>
      )}
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((gal) => {
    const mains = gal.querySelectorAll<HTMLElement>('[data-main-img]');
    const thumbs = gal.querySelectorAll<HTMLElement>('[data-thumb]');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const i = thumb.dataset.thumb;
        mains.forEach((m) =>
          m.classList.toggle('is-active', m.dataset.mainImg === i),
        );
        thumbs.forEach((t) =>
          t.classList.toggle('is-active', t.dataset.thumb === i),
        );
      });
    });
  });
</script>

<style>
  .gallery-main {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .gallery-main :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .gallery-main :global(img.is-active) {
    opacity: 1;
  }

  .gallery-thumbs {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    flex-wrap: wrap;
  }
  .thumb {
    width: 68px;
    height: 68px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    background: var(--color-surface);
    transition: border-color 0.15s ease;
  }
  .thumb :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb.is-active {
    border-color: var(--color-accent);
  }
</style>
