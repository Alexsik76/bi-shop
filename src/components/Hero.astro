---
import { Image } from 'astro:assets';
import rabbitImg from '../assets/hero-rabbit.png';
import OrderButton from './OrderButton.astro';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="eyebrow">Ручна робота · натуральні матеріали</p>
      <h1>Теплі в'язані іграшки,<br />створені з любов’ю</h1>
      <p class="hero-lead">
        Кожна іграшка народжується під руками майстрині — від першої петельки
        до останнього вузлика. М’які, безпечні й теплі, як бабусині обійми.
      </p>
      <div class="hero-actions">
        <a href="#katalog" class="btn btn-primary">Переглянути каталог</a>
        <OrderButton label="Написати в Telegram" variant="outline" />
      </div>
    </div>

    <div class="hero-illustration">
      <Image
        src={rabbitImg}
        width={389}
        height={420}
        alt="В'язаний заєць із клубком пряжі"
        loading="eager"
        fetchpriority="high"
        class="hero-img"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 7vw, 5rem);
    overflow: hidden;
    background: var(--color-bg);
  }
  .hero-inner {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .hero-text {
    max-width: 60ch;
  }
  .hero-lead {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 42ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .hero-illustration {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-img {
    display: block;
    max-height: 260px;
    width: auto;
    height: auto;
    mask-image: radial-gradient(circle, rgba(0, 0, 0, 1) 78%, rgba(0, 0, 0, 0) 100%);
    -webkit-mask-image: radial-gradient(circle, rgba(0, 0, 0, 1) 78%, rgba(0, 0, 0, 0) 100%);
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1.2fr 0.8fr;
      gap: 4rem;
    }
    .hero-img {
      max-height: 420px;
    }
  }
</style>
